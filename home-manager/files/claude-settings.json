{
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "telegram": {
      "command": "npx",
      "args": ["-y", "telegram@claude-plugins-official"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/sudo-check.sh"
          }
        ]
      }
    ]
  },
  "web_fetch": {
    "allowed_domains": ["*"]
  }
}
